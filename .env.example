# Secrets are NOT set here — they live in Locksmith (macOS keychain).
# Add:  locksmith add <NAME>      Group: locksmith group first-agentic <NAME>...
# Run:  withkeys @first-agentic -- <command>

# NEBIUS_API_KEY -> Locksmith: locksmith add NEBIUS_API_KEY
# TAVILY_API_KEY -> Locksmith: locksmith add TAVILY_API_KEY
# LINKUP_API_KEY -> Locksmith: locksmith add LINKUP_API_KEY
# Image generation (Creative Director → Artist preset) — https://fal.ai/dashboard/keys
# FAL_KEY -> Locksmith: locksmith add FAL_KEY
SEARCH_PROVIDER=auto
